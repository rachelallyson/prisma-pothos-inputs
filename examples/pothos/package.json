{
  "name": "pothos-prisma-example",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "graphql-codegen",
    "generate:inputs": "cd ../.. && npm run build && node dist/bin.js --schema examples/pothos/prisma/schema.prisma --output-pothos examples/pothos/src/__generated__/pothos-inputs.ts --prisma-client-path ../../generated/prisma/client.js --use-relation-inputs",
    "prisma:generate": "prisma generate",
    "build": "tsc",
    "verify": "tsc --noEmit",
    "print-schema": "npm run build && node dist/src/print-schema.js",
    "start": "tsx src/server.ts"
  },
  "dependencies": {
    "@rachelallyson/prisma-pothos-inputs": "file:../..",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-prisma": "^4.14.2",
    "dotenv": "^16.4.0",
    "graphql": "^16.12.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/typescript": "^5.0.7",
    "prisma": "^7.0.0",
    "typescript": "^5.9.3"
  }
}
